@page "/orders/export"

<PageTitle>申込CSV出力</PageTitle>

<MudGrid Class="mb-6">
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-6" Elevation="1">
            <MudStack Spacing="3">
                <MudStack>
                    <MudText Typo="Typo.h5">申込CSV出力</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">株主優待の申込データを CSV で出力します。</MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_serverErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" NoIcon="true">
                        @_serverErrorMessage
                    </MudAlert>
                }

                <MudRadioGroup T="string" @bind-Value="_selectedScope">
                    <MudRadio T="string" Value="@ExportScopeUnexported" Color="Color.Primary">未出力のみ</MudRadio>
                    <MudRadio T="string" Value="@ExportScopeAll" Color="Color.Primary">全件</MudRadio>
                </MudRadioGroup>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleExportAsync">
                        CSVを出力
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">出力モード</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string">未出力のみ: 未出力の申込だけを CSV 出力し、出力済みに更新します。</MudListItem>
                <MudListItem T="string">全件: 出力済みを含めて再出力します。出力済み状態は変更しません。</MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>
