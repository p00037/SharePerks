@page "/confirm"
@using User.Client.Services
@using Shared.Dtos
@implements IDisposable
@inject NavigationManager NavigationManager
@using User.Client.Services.Api.Exceptions
@using User.Client.Services.Api.Interface
@inject IShareholderOrderApiClient OrderApiClient
@inject RewardSelectionState SelectionState

<PageTitle>申込内容確認</PageTitle>

<MudGrid Class="mb-6">
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-6" Elevation="1">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h5">申込内容確認</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">内容をご確認のうえ、申し込みを確定してください。</MudText>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <MudAlert Severity="Severity.Error">
                        <MudText>@errorMessage</MudText>
                        @if (validationErrors != null && validationErrors.Any())
                        {
                            <ul class="mt-2">
                                @foreach (var error in validationErrors.Values.SelectMany(x => x))
                                {
                                    <li><MudText Typo="Typo.body2">@error</MudText></li>
                                }
                            </ul>
                        }
                    </MudAlert>
                }

                <MudPaper Class="pa-4" Elevation="1" Outlined="true">
                    <MudText Typo="Typo.h6" Class="mb-2">送付先情報</MudText>
                    <MudText Typo="Typo.body2">郵便番号: @SelectionState.Address.PostalCode</MudText>
                    <MudText Typo="Typo.body2">電話番号: @SelectionState.Address.PhoneNumber</MudText>
                    <MudText Typo="Typo.body2">住所1: @SelectionState.Address.Address1</MudText>
                    <MudText Typo="Typo.body2">住所2: @SelectionState.Address.Address2</MudText>
                    @if (!string.IsNullOrWhiteSpace(SelectionState.Address.Address3))
                    {
                        <MudText Typo="Typo.body2">住所3: @SelectionState.Address.Address3</MudText>
                    }
                </MudPaper>

                <MudPaper Class="pa-4" Elevation="1" Outlined="true">
                    <MudText Typo="Typo.h6" Class="mb-2">申込商品</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var item in SelectionState.SelectedItems)
                        {
                            <MudListItem Text="@($"{item.ItemName}（数量: {item.Quantity} / 小計: {item.RequiredPoints * item.Quantity}pt）")" />
                        }
                    </MudList>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1" Align="Align.Right">合計ポイント: <b>@SelectionState.TotalPoints pt</b></MudText>
                </MudPaper>

                <MudCheckBox T="bool" @bind-Value="isAgreed" Label="内容を確認し、申し込みに同意します。" Color="Color.Primary" />

                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanSubmit || isSubmitting)" OnClick="SubmitOrderAsync">
                        @(isSubmitting ? "処理中..." : "申し込みを確定する")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@isSubmitting" OnClick="MoveToAddress">
                        入力画面へ戻る
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool isAgreed;
    private bool isSubmitting;
    private string? errorMessage;
    private IReadOnlyDictionary<string, string[]>? validationErrors;
    private readonly CancellationTokenSource cts = new();

    private bool CanSubmit => SelectionState.SelectedItems.Count > 0
                              && !string.IsNullOrWhiteSpace(SelectionState.Address.PostalCode)
                              && !string.IsNullOrWhiteSpace(SelectionState.Address.Address1)
                              && !string.IsNullOrWhiteSpace(SelectionState.Address.Address2)
                              && !string.IsNullOrWhiteSpace(SelectionState.Address.PhoneNumber)
                              && isAgreed;

    protected override void OnInitialized()
    {
        if (SelectionState.SelectedItems.Count == 0)
        {
            NavigationManager.NavigateTo("/items");
            return;
        }

        var addr = SelectionState.Address;
        if (string.IsNullOrWhiteSpace(addr.PostalCode)
            || string.IsNullOrWhiteSpace(addr.Address1)
            || string.IsNullOrWhiteSpace(addr.Address2)
            || string.IsNullOrWhiteSpace(addr.PhoneNumber))
        {
            NavigationManager.NavigateTo("/address");
        }
    }

    private void MoveToAddress()
    {
        NavigationManager.NavigateTo("/address");
    }

    private async Task SubmitOrderAsync()
    {
        if (!CanSubmit || isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        validationErrors = null;

        var request = new CreateRewardOrderRequestDto(
            SelectionState.Address.PostalCode,
            SelectionState.Address.Address1,
            SelectionState.Address.Address2,
            SelectionState.Address.Address3,
            SelectionState.Address.PhoneNumber,
            SelectionState.SelectedItems.Select(x => new CreateRewardOrderItemRequestDto(x.ItemId, x.Quantity)).ToList());

        try
        {
            var result = await OrderApiClient.CreateAsync(request, cts.Token);
            SelectionState.Clear();
            NavigationManager.NavigateTo($"/complete?orderId={result.OrderId}");
        }
        catch (ApiValidationException ex)
        {
            errorMessage = ex.Message;
            validationErrors = ex.Errors;
        }
        catch (OperationCanceledException)
        {
            // キャンセル時は何もしない
        }
        catch (Exception)
        {
            errorMessage = "申し込み登録に失敗しました。通信状況を確認し、時間をおいて再度お試しください。";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }
}
