@page "/"
@page "/items"
@using Shared.Dtos
@using User.Client.Components
@using User.Client.Services
@using User.Client.Services.Api.Interface
@inject NavigationManager NavigationManager
@inject RewardSelectionState SelectionState
@inject IShareholderOrderApiClient OrderApiClient
@inject IShareholderItemApiClient ItemApiClient

@inherits FormComponentBase<List<RewardItemSummaryDto>>

<PageTitle>優待商品選択</PageTitle>

<MudGrid Class="mb-6">
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-6" Elevation="1">
            <MudStack Spacing="2">
                <MudStack>
                    <MudText Typo="Typo.h5">優待商品を選択</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">ご希望の優待商品を選択してください。選択後に住所入力へ進めます。</MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_serverErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                        @_serverErrorMessage
                    </MudAlert>
                }
                else if (SelectionState.IsExported)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                        申込内容は既に出力済みのため更新できません。保存済みの内容のみ確認できます。
                    </MudAlert>
                }
                else if (SelectionState.HasExistingOrder)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        保存済みの申込内容を表示しています。数量を変更して更新できます。
                    </MudAlert>
                }

                @if (_editContext is not null)
                {
                    <EditForm EditContext="_editContext" OnSubmit="HandleMoveToAddressAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        @if (_formModel.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                現在選択できる優待商品がありません。
                            </MudAlert>
                        }
                        else
                        {
                            <MudGrid>
                                @foreach (var item in _formModel)
                                {
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudCard Class="@GetCardClass(item)" Elevation="@(IsSelected(item) ? 6 : 1)">
                                            <MudCardMedia Image="@GetImagePath(item)" Height="180" />
                                            <MudCardContent>
                                                <MudText Typo="Typo.h6">@item.ItemName</MudText>
                                                <MudText Typo="Typo.body2" Class="mb-2">@item.ItemDescription</MudText>
                                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">
                                                    必要ポイント: @item.RequiredPoints
                                                </MudChip>
                                            </MudCardContent>
                                            <MudCardActions>
                                                <MudNumericField T="int"
                                                                 Label="数量"
                                                                 Min="0"
                                                                 Max="99"
                                                                 Value="@GetQuantity(item)"
                                                                 ValueChanged="value => UpdateQuantity(item, value)"
                                                                 Disabled="@SelectionState.IsExported" />
                                            </MudCardActions>
                                        </MudCard>
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       ButtonType="ButtonType.Submit"
                                       Disabled="@(!CanProceed)">
                                @(SelectionState.IsExported ? "保存済み住所を確認する" : "住所等の入力へ進む")
                            </MudButton>
                        </MudStack>
                    </EditForm>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">選択中の商品</MudText>

            @if (SelectedItems.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">まだ優待商品が選択されていません。</MudText>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in SelectedItems)
                    {
                        <MudListItem Text="@($"{item.ItemName}・数量 {item.Quantity} / 合計 {item.RequiredPoints * item.Quantity}pt")" />
                    }
                </MudList>
            }

            <MudDivider Class="my-2" />
            <MudText Typo="Typo.body2">合計ポイント: @TotalPoints / @AvailablePoints</MudText>

            @if (TotalPoints > AvailablePoints)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">
                    選択した合計ポイントが使用可能ポイントを超えています。
                </MudAlert>
            }
        </MudPaper>
    </MudItem>
</MudGrid>
